{
  "name": "caliber-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Project Caliber — Talent Intelligence Platform frontend (React + Vite + MUI v9).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/build-search-console.js && node scripts/prerender.js && node scripts/verify-prerender.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:prerender": "node scripts/verify-prerender.js",
    "lighthouse": "lhci autorun",
    "lighthouse:ci": "lhci autorun"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@tanstack/react-query": "^5.101.2",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "motion": "^12.42.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/i18next": "^12.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
