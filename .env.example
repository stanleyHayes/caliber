# Copy to .env (gitignored). Never commit real secrets.
CALIBER_ENV=dev
CALIBER_LOG_LEVEL=info
CALIBER_HTTP_ADDR=:8080
CALIBER_GRPC_ADDR=:9090
CALIBER_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres + pgvector
CALIBER_DATABASE_URL=postgres://caliber:caliber@localhost:5432/caliber?sslmode=disable

# Redis (Asynq)
CALIBER_REDIS_URL=redis://localhost:6379/0
CALIBER_WORKER_CONCURRENCY=4

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Auth
CALIBER_JWT_SECRET=

# Rate limiting (CAL-112) — per-principal token bucket. Generous defaults; no
# human-driven session approaches these, but they cap floods on AI endpoints.
CALIBER_RATE_LIMIT_RPS=30
CALIBER_RATE_LIMIT_BURST=60

# Talent Radar dashboard snapshot TTL (CAL-080). Caches pool, supply/demand,
# alerts, and time-to-shortlist so live dashboard panels render snappily.
CALIBER_DASHBOARD_CACHE_TTL=30s

# Interview session caps (CAL-104). The interview ends when either limit is hit,
# keeping the demo inside a tight latency budget.
CALIBER_INTERVIEW_MAX_QUESTIONS=4
CALIBER_INTERVIEW_MAX_DURATION=10m

# Seed generation pipeline (CAL-098). When true, the in-memory dev stack boots
# with 50–60 parser-generated CVs/profiles, 6–8 employers, and 8–12 roles.
CALIBER_SEED_GENERATED=false

# Frontend: privacy-respecting analytics & Search Console verification (CAL-128).
# All values are optional and disabled when left blank.
# VITE_PLAUSIBLE_DOMAIN=projectcaliber.app
# VITE_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
# VITE_PLAUSIBLE_API_URL=https://plausible.io/api/event
# VITE_WEB_VITALS_ENDPOINT=https://projectcaliber.app/api/web-vitals
# VITE_SEARCH_CONSOLE_VERIFICATION=abc123
# VITE_SEARCH_CONSOLE_HTML_FILE_TOKEN=abc123
