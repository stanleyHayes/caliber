  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {"expr": "sum(rate(caliber_queue_enqueued_total[5m]))", "refId": "A"}
      ],
      "title": "Enqueue Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {"expr": "sum(rate(caliber_queue_jobs_processed_total[5m])) by (status)", "refId": "A", "legendFormat": "{{status}}"}
      ],
      "title": "Job Processing Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {"expr": "sum(rate(caliber_queue_jobs_processed_total{status=\"error\"}[5m])) / sum(rate(caliber_queue_jobs_processed_total[5m]))", "refId": "A"}
      ],
      "title": "Job Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(caliber_queue_job_duration_seconds_bucket[5m])) by (le))", "refId": "A"}
      ],
      "title": "Job p95 Duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "targets": [
        {"expr": "{service=\"caliber-worker\"} |= \"job failed\"", "refId": "A"}
      ],
      "title": "Failed Job Logs",
      "type": "logs"
    }
  ],
